# Copy file này thành .env và điền giá trị thật trước khi `docker compose up`

# Docker Hub user/namespace (để pull image đúng repo)
DOCKER_USERNAME=nphng15

# Tag image: latest, v1.0.0, sha-xxxxx ...
TAG=latest

# JWT — BẮT BUỘC phải đổi ở production
JWT_SECRET=please_change_me_to_a_strong_random_string
JWT_EXPIRES_IN=2h

# Cloudinary (lấy từ dashboard Cloudinary, dạng: cloudinary://<key>:<secret>@<cloud_name>)
CLOUDINARY_URL=
